<div class="mootimetersettings mootimeterfullwidth">

    {{> mod_mootimeter/elements/snippet_settings_col_header}}

    {{#question}}
    {{> mod_mootimeter/elements/snippet_textarea}}
    {{#js}}
    require(['mod_mootimeter/reload_page_content'], (module) => module.init("{{mtm-input-id}}_{{uniqid}}"));
    {{/js}}
    {{/question}}

    {{> mod_mootimeter/elements/snippet_divider}}

    <p class="text-bold">{{#str}} answeroptions , mootimetertool_quiz {{/str}}</p>

    {{^ispoll}}
        {{#notification_mark_correct_anser}}
            {{> mod_mootimeter/elements/snippet_notification}}
        {{/notification_mark_correct_anser}}
    {{/ispoll}}

    <div class="input-with-checkbox-icon_wrapper" id="mtmt-quiz-ao-wrapper">
        {{#answeroptions}}
        {{> mod_mootimeter/elements/snippet_input_with_checkbox-icon}}
        {{#js}}
        require(['mootimetertool_quiz/remove_answer_option'], (module) => module.init("{{button_icon_only_transparent_id}}_{{uniqid}}"));
        require(['mod_mootimeter/reload_page_content'], (module) => module.init("{{mtm-input-id}}_{{uniqid}}"));
        require(['mod_mootimeter/reload_page_content'], (module) => module.init("{{button_icon_only_transparent_id}}_{{uniqid}}"));
        require(['mod_mootimeter/reload_page_settings'], (module) => module.init("{{button_icon_only_transparent_id}}_{{uniqid}}"));
        {{/js}}
        {{/answeroptions}}
    </div>

    {{#addoption}}
    {{> mod_mootimeter/elements/snippet_button_icon_with_text}}
    {{#js}}
    require(['mootimetertool_quiz/add_new_answer_option'], (module) => module.init("wrapper_add_answer_option_{{uniqid}}"));
    require(['mod_mootimeter/reload_page_content'], (module) => module.init("{{button_icon_only_transparent_id}}_{{uniqid}}"));
    require(['mod_mootimeter/reload_page_settings'], (module) => module.init("{{button_icon_only_transparent_id}}_{{uniqid}}"));
    {{/js}}
    {{/addoption}}

    {{> mod_mootimeter/elements/snippet_divider}}

    <div class="mootimeter-diagram-type-row">
        <span class="mootimeter-diagram-type-label">{{#str}} diagram_type , mootimetertool_quiz {{/str}}</span>
        <div class="mootimeter-visualization-options-wrapper">
            {{#visualization}}
            {{> mod_mootimeter/elements/snippet_settings_visualization_option}}
            {{/visualization}}
            {{#js}}
            require(['mootimetertool_quiz/store_visualization'], (module) => module.init("{{uniqid}}"));
            {{/js}}
        </div>
    </div>

    {{> mod_mootimeter/elements/snippet_divider}}

    <div class="mootimeter-actions-list">
        {{#icon-eye}}
        {{> mod_mootimeter/elements/snippet_button_action}}
        {{#js}}
        require(['mod_mootimeter/toggle_state'], (module) => module.init(["{{id}}_{{uniqid}}"]));
        {{/js}}
        {{/icon-eye}}

        {{#icon-answer-overview}}
        {{> mod_mootimeter/elements/snippet_button_action}}
        {{#js}}
        require(['mod_mootimeter/reload_page'], (module) => module.init(["{{id}}_{{uniqid}}"]));
        {{/js}}
        {{/icon-answer-overview}}

        {{#icon-restart}}
        {{> mod_mootimeter/elements/snippet_button_action}}
        {{#js}}
        require(['mod_mootimeter/handle_button_clicked'], (module) => module.init(["{{id}}_{{uniqid}}"]));
        {{/js}}
        {{/icon-restart}}
    </div>

    {{> mod_mootimeter/elements/snippet_divider}}

    <p class="text-bold">{{#str}} settings {{/str}}</p>

    {{#maxanswers}}
    {{> mod_mootimeter/elements/snippet_number_input}}
    {{/maxanswers}}

    {{#anonymousmode}}
    {{> mod_mootimeter/elements/snippet_checkbox_with_label}}
    {{/anonymousmode}}
</div>